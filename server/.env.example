PORT=5000
MONGO_URI=mongodb://localhost:27017/nirman-setu
CLIENT_URL=http://localhost:5173

# Gmail SMTP — use App Password (not your real password)
# Enable 2FA on Gmail → My Account → Security → App Passwords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

ADMIN_EMAIL=your_admin_email@gmail.com

# Meta WhatsApp Cloud API — developers.facebook.com se milega
# WhatsApp > Getting Started > Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
# System User se generate karo permanent token
WHATSAPP_TOKEN=your_permanent_access_token_here
